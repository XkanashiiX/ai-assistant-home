modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Voice Agent"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv run friday"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Voice Agent"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv run friday_voice"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 8000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["uv", "run", "friday"]

[userenv]

[userenv.shared]
MCP_SERVER_URL = "https://gorged-vitamins-decimal.ngrok-free.dev/sse"
